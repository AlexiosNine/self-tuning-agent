# Ensure consistent line endings across all platforms
* text=auto eol=lf

# Python files
*.py text eol=lf

# Configuration files
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Markdown and documentation
*.md text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf
